generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  role         String    @default("client")
  company_name String?
  db_name      String?
  createdAt    DateTime  @default(now())
}
